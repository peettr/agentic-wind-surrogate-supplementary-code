# Condor submit template for auto_v6 training jobs on CRC (<HPC_FILE_LOGIN>).
#
# Variables substituted via string.Template.safe_substitute:
#   JOB_NAME, SCRIPT_PATH, CONFIG_PATH, RESULTS_DIR, STRATEGY, SEED, PYTHON
#
# NOTES
# -----
# 1. GPU ClassAd matches on Machine hostname (per CRC Dodi, verified Job
#    17731 on H100). Do NOT use CUDACapability â€” that field is numeric
#    (7.5, 8.0, 9.0) and will not match model name strings like "H100".
# 2. request_memory defaults to 16 GB host RAM; GPU OOM is handled by GPU class/VRAM, not by over-requesting host RAM.
# 3. request_cpus is intentionally unset â€” let Condor auto-assign.
# 4. AFS is unreachable from the compute nodes (no AFS token), so all
#    paths must live under <HPC_USER_ROOT>/... which is shared.
#    Run `fs setacl <BASELINE_HPC_SOURCE_ROOT> nd_campus read`
#    once to grant readable ACLs to the executors.
# 5. The training script writes metrics.json / sentinels directly to the
#    absolute $RESULTS_DIR on the shared filesystem â€” Condor file
#    transfer is NOT used (see should_transfer_files=NO below).
# 6. Condo GPUs (H100/A100/L40S) can be preempted by their owners; the
#    executor detects this via JobStatus and resumes from checkpoint.pt.

universe                = vanilla
executable              = /usr/bin/env
arguments               = "$PYTHON $SCRIPT_PATH --config $CONFIG_PATH"

getenv                  = True
environment             = "AUTO_V6_STRATEGY=$STRATEGY PYTHONUNBUFFERED=1 AUTO_V6_SEED=$SEED"

request_gpus            = 1
request_memory          = $REQUEST_MEMORY_GB GB

# CRC GPU machines matched by hostname prefix.
# Use true high-memory GPUs only for 640x640 V4 experiments.
# Exclude A10/2080Ti and qa-rtx6k Quadro RTX 6000 slots, which are 22GB in this pool.
# Also exclude qa-a40-003 after repeated standard-output Permission denied holds.
requirements            = ((regexp("qa-h100-", Machine) || regexp("qa-a100-", Machine) || regexp("qa-l40s-", Machine) || regexp("qa-a40-", Machine) || regexp("ta-a6k-", Machine)) && !regexp("qa-a40-003", Machine))

output                  = $RESULTS_DIR/condor.out
error                   = $RESULTS_DIR/condor.err
log                     = $RESULTS_DIR/condor.log

initialdir              = $RESULTS_DIR

# Shared-filesystem mode: training writes metrics/sentinels/models
# directly to $RESULTS_DIR. No Condor file transfer â€” avoids the
# CWD-vs-absolute-path conflict that previously held jobs on transfer.
should_transfer_files   = NO

# Default on_exit_remove: job stays in queue on failure (held), easier debugging.
# On eviction, shared/train.py resumes from checkpoint.pt (saved every 50 epochs).

+JobBatchName           = "$JOB_NAME"
queue 1

