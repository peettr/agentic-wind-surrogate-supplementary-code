universe = vanilla
executable = /bin/bash
arguments = <GRID_HPC_SOURCE_ROOT>/reports/holdout_eval_auto11_top/eval_holdout_top.sh
getenv = True
environment = "PYTHONUNBUFFERED=1 AUTO_V3_STRATEGY=auto11_holdout_eval"
request_gpus = 1
request_memory = 24 GB
request_disk = 8 GB
requirements = (regexp("qa-h100-", Machine))
output = <GRID_HPC_SOURCE_ROOT>/reports/holdout_eval_auto11_top/condor.out
error = <GRID_HPC_SOURCE_ROOT>/reports/holdout_eval_auto11_top/condor.err
log = <GRID_HPC_SOURCE_ROOT>/reports/holdout_eval_auto11_top/condor.log
initialdir = <GRID_HPC_SOURCE_ROOT>/reports/holdout_eval_auto11_top
should_transfer_files = NO
on_exit_remove = (ExitBySignal == False) && (ExitCode == 0)
+JobBatchName = "auto11_holdout_eval_top"
queue 1
